# Production environment template for root docker-compose
# Copy to .env on EC2 and set real values.

# Public base URL used by frontend-visible links
# Example: http://13.52.10.20 or https://labs.example.com
PUBLIC_BASE_URL=http://YOUR_EC2_PUBLIC_IP

# OpenAI
OPENAI_API_KEY=REPLACE_WITH_REAL_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini
LLM_MODEL=gpt-4o-mini

# Portal
PORTAL_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET
PORTAL_DEBUG=False

# LAB-1
LAB1_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# LAB-2
LAB2_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
LAB2_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# LAB-3
LAB3_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
LAB3_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# LAB-4
LAB4_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
LAB4_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# LAB-5
DATABASE_URL=sqlite:///govconnect.db
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
