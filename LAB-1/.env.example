# MedAssist AI - LAB-1 Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# OpenAI API Configuration
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here

# Model Selection (gpt-4o-mini is recommended for this lab)
LLM_MODEL=gpt-4o-mini

# ===========================================
# Application Configuration
# ===========================================
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=super_secret_key_change_me_in_production
JWT_SECRET=jwt_secret_key_for_tokens

# Server Configuration
HOST=0.0.0.0
PORT=5000

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=sqlite:///database/medassist.db

# ===========================================
# Security Settings (INTENTIONALLY WEAK FOR LAB)
# ===========================================
DISABLE_AUTH=False
ADMIN_API_KEY=admin_secret_123
ALLOW_RAG_UPLOADS=True
ENABLE_DEBUG_MODE=True

# ===========================================
# Agent Configuration
# ===========================================
MAX_TOKENS=4096
TEMPERATURE=0.7
ENABLE_FUNCTION_CALLING=True
AGENT_VERBOSE_MODE=True

# ===========================================
# RAG Configuration
# ===========================================
CHROMA_PERSIST_DIR=./rag/chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
