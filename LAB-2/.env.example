# LAB-2: SecureBank AI — Environment Configuration
# Copy to .env and fill in your OPENAI_API_KEY

# Database
DATABASE_URL=postgresql://bankadmin:SecureBank2024!@postgres:5432/securebank

# Redis
REDIS_URL=redis://redis:6379

# OpenAI (primary LLM — gpt-4o-mini)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development
DEBUG=True

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# AI Configuration
MAX_TOKENS=2048
TEMPERATURE=0.7

# Vulnerability Mode (Set to False to enable security features)
ENABLE_VULNERABLE_MODE=True
