# LAB-3: ShopSec AI — Environment Configuration
# Copy to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://shopsec:shopsec123@localhost:5432/shopsec_db
POSTGRES_USER=shopsec
POSTGRES_PASSWORD=shopsec123
POSTGRES_DB=shopsec_db

# AI Models — OpenAI is primary (gpt-4o-mini)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Security
SECRET_KEY=change-this-secret-key-in-production
JWT_SECRET=change-this-jwt-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_PASSWORD=admin123

# Feature Flags
ENABLE_GUARDRAILS=false
ENABLE_MONITORING=true
ENABLE_TRAFFIC_GEN=false
ENABLE_LOGGING=true
LOG_LEVEL=INFO

# Stripe Mock
STRIPE_MOCK_PORT=8004
STRIPE_PUBLISHABLE_KEY=pk_test_mock
STRIPE_SECRET_KEY=sk_test_mock

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Service URLs (Internal)
ORDER_SERVICE_URL=http://localhost:8001
SEARCH_SERVICE_URL=http://localhost:8002
AGENT_SERVICE_URL=http://localhost:8003
PAYMENT_SERVICE_URL=http://localhost:8004

# Agent Configuration
MAX_DISCOUNT_PERCENT=15
MIN_PRICE_THRESHOLD=10
MAX_CART_ITEMS=50
REFUND_WINDOW_DAYS=30

# RAG Configuration
VECTOR_SEARCH_TOP_K=5
ENABLE_CONTEXT_TAINTING=false
MAX_CONTEXT_LENGTH=4000

# Monitoring
ENABLE_THOUGHT_CHAIN_LOGGING=true
ENABLE_ANOMALY_DETECTION=false
